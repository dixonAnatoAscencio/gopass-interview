{
  "name": "gopass-interview",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:web": "nx serve web",
    "start:api": "nx serve api",
    "start:worker": "nx serve worker",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "build:worker": "nx build worker",
    "build:all": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:web": "nx test web",
    "test:api": "nx test api",
    "test:worker": "nx test worker",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed": "ts-node apps/api/prisma/seed.ts",
    "db:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prepare": "husky install || true"
  },
  "private": true,
  "devDependencies": {
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/nest": "22.7.5",
    "@nx/react": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "nx": "22.7.5",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.5.2",
    "vite": "^5.4.14",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.16.2",
    "@tanstack/react-query": "^5.51.1",
    "@tanstack/react-query-devtools": "^5.51.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^5.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-router-dom": "^6.24.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  }
}
